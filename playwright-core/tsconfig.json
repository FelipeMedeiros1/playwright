{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationDir": "./dist",
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "Web/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "e2e"
  ]
}
