{
  "name": "playwright-core",
  "version": "1.0.0",
  "description": "Projeto de automação Playwright com suporte a Allure Reports",
  "main": "index.ts",
  "types": "index.ts",
  "type": "commonjs",
  "files": [
    "index.ts",
    "Web/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "report:html": "playwright show-report",
    "report:allure": "allure generate -c allure-results -o allure-report",
    "report:allure:open": "allure serve allure-results"
  },
