    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.54.0",
    "allure-js-commons": ">=2.14.0",
    "allure-playwright": ">=3.3.3",
    "playwright": ">=1.54.0"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "js-yaml": "^4.1.1",
    "pdf-parse": "^1.1.1"
