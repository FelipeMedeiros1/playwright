{
    "name":  "parabank",
    "version":  "1.0.0",
    "description":  "Testes E2E Parabank - depende de playwright-core",
    "main":  "index.js",
    "type":  "commonjs",
    "scripts":  {
                    "test":  "playwright test",
                    "test:headed":  "playwright test --headed",
                    "test:ui":  "playwright test --ui",
                    "report:html":  "playwright show-report",
                    "report:allure":       "allure generate -c allure-results -o allure-report",
                    "report:allure:open":  "allure open allure-report",
                    "report:allure:reset": "npx rimraf allure-results allure-report && echo Historico e resultados limpos. Execute npm test para uma nova execucao.",
                    "prepare":  "git config core.hooksPath .githooks && playwright install --with-deps"
                },
    "keywords":  [

                 ],
    "author":  "",
    "license":  "ISC",
    "dependencies":  {
                         "playwright-core":  "*"
                     },
    "devDependencies":  {
                            "@playwright/test":  "^1.54.2",
                            "@types/node":  "^24.2.1",
                            "allure-commandline":  "^2.34.1",
                            "allure-js-commons":  "^2.14.0",
                            "allure-playwright":  "^3.3.3",
                            "playwright":  "^1.54.2",
                            "ts-node":  "^10.9.2",
                            "typescript":  "^5.9.2"
                        }
}
