{
    "name":  "automation-workspace",
    "version":  "1.0.0",
    "private":  true,
    "workspaces":  [
                       "playwright-core",
                       "projetos/*"
                   ],
    "scripts":  {
                    "install:all":         "npm install --ignore-scripts",
                    "novo-projeto":        "powershell -ExecutionPolicy Bypass -File scripts/novo-projeto.ps1 -Nome",
                    "report:allure:reset": "npm run report:allure:reset --workspaces --if-present",
                    "report:allure":       "npm run report:allure --workspaces --if-present"
                }
}
